# AEP 2.8 Docker deploy - copy to .env and adjust
#   cp .env.example .env

# Published ports (host:container is fixed at 8424/8412 inside the image)
COMPOSER_LITE_PORT=8424
UCB_PORT=8412

# Optional URL prefix when behind a reverse proxy (e.g. /lite)
COMPOSER_LITE_BASE_PATH=

# Required for remote setup wizard access (non-loopback). Generate with: openssl rand -hex 32
# Open install wizard as: http://host:8424/install?setup_token=YOUR_TOKEN
COMPOSER_LITE_SETUP_TOKEN=

# UCB API key (recommended for production). Auto-generated on first boot if empty.
UCB_API_KEY=

# Inference for setup agent / CCA (OpenRouter example)
AEP_SETUP_LLM_PROVIDER=openrouter
AEP_SETUP_LLM_MODEL=anthropic/claude-sonnet-4
OPENROUTER_API_KEY=

# Set to 1 for non-interactive first-boot activation (optional)
AEP_AUTO_SETUP=0

# Optional tier-1 GAP engine (licensed / self-hosted; not bundled in public OSS)
# UCB_GAP_ENGINE_URL=https://your-gap-engine/synthesize
# NLA_GAP_ENGINE_URL=https://your-gap-engine/synthesize