{
 "$schema": "https://json-schema.org/draft/2020-12/schema",
 "$id": "https://aep.protocol.local/schemas/component-manifest-v1.json",
 "title": "AEP Component Manifest v1",
 "type": "object",
 "required": [
 "manifest_version",
 "id",
 "version",
 "kind",
 "path",
 "description",
 "requires",
 "capabilities",
 "actions",
 "setup_hooks",
 "resource_requirements",
 "cca",
 "implementation"
 ],
 "properties": {
 "manifest_version": { "const": "1" },
 "id": { "type": "string", "minLength": 1 },
 "version": { "type": "string" },
 "kind": {
 "type": "string",
 "enum": [
 "protocol",
 "daemon",
 "library",
 "ui",
 "bridge",
 "wasm",
 "regulation",
 "compliance",
 "tooling",
 "agent",
 "connector",
 "wasm_extension",
 "template",
 "wizard"
 ]
 },
 "path": { "type": "string", "minLength": 1 },
 "description": { "type": "string", "minLength": 1 },
 "requires": { "type": "array", "items": { "type": "string" } },
 "depends_on": { "type": "array", "items": { "type": "string" } },
 "conflicts_with": { "type": "array", "items": { "type": "string" } },
 "lrp_id": { "type": "string" },
 "gap_ref": { "type": "string" },
 "docks": {
 "type": "object",
 "properties": {
 "primary": { "type": ["string", "null"] },
 "allowed": { "type": "array", "items": { "type": "string" } }
 }
 },
 "capabilities": { "type": "array", "items": { "type": "string" } },
 "actions": {
 "type": "array",
 "items": {
 "type": "object",
 "required": ["id", "description"],
 "properties": {
 "id": { "type": "string" },
 "description": { "type": "string" },
 "setup_hook": { "type": "string" },
 "runtime": { "type": "string" },
 "method": { "type": "string" },
 "params": { "type": "object" }
 }
 }
 },
 "setup_hooks": {
 "type": "array",
 "items": {
 "type": "object",
 "required": ["id"],
 "properties": {
 "id": { "type": "string" },
 "policy_section": { "type": "string" },
 "default": { "type": "object" },
 "setup_hook": { "type": "string" },
 "params": { "type": "object" }
 }
 }
 },
 "resource_requirements": {
 "type": "object",
 "required": ["min_memory_mb", "min_disk_mb", "requires_internet", "gpu_required"],
 "properties": {
 "min_memory_mb": { "type": "number" },
 "min_disk_mb": { "type": "number" },
 "requires_internet": { "type": "boolean" },
 "gpu_required": { "type": "boolean" }
 }
 },
 "composer": {
 "type": "object",
 "properties": {
 "palette": { "type": "boolean" },
 "node_type": { "type": ["string", "null"] }
 }
 },
 "composer_node": { "type": "object" },
 "cca": {
 "type": "object",
 "required": ["summary", "use_when", "avoid_when"],
 "properties": {
 "summary": { "type": "string" },
 "use_when": { "type": "array", "items": { "type": "string" } },
 "avoid_when": { "type": "array", "items": { "type": "string" } },
 "pairs_with": { "type": "array", "items": { "type": "string" } },
 "example_snippet": { "type": "string" }
 }
 },
 "implementation": { "type": "object" },
 "conformance": {
 "type": "object",
 "properties": {
 "tests": { "type": "array", "items": { "type": "string" } }
 }
 }
 },
 "additionalProperties": true
}