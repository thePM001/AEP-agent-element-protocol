{
  "manifest_version": "1",
  "id": "optimization",
  "version": "2.8.0",
  "kind": "library",
  "path": "AEP-Components/optimization/",
  "description": "Governed prompt optimizer and version manager.",
  "requires": [
    "eval",
    "covenant",
    "aep-typescript-sdk"
  ],
  "capabilities": [
    "optimize:prompt",
    "optimize:version"
  ],
  "actions": [],
  "setup_hooks": [],
  "resource_requirements": {
    "min_memory_mb": 128,
    "min_disk_mb": 30,
    "requires_internet": false,
    "gpu_required": false
  },
  "cca": {
    "summary": "Prompt optimization under covenant and eval constraints.",
    "use_when": [
      "prompt tuning with governance"
    ],
    "avoid_when": [],
    "pairs_with": []
  },
  "implementation": {
    "module": "AEP-Components/optimization/lib/optimizer.ts"
  }
}
