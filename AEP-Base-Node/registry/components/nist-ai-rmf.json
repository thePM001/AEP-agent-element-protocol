{
  "manifest_version": "1",
  "id": "nist-ai-rmf",
  "version": "2.8.0",
  "kind": "compliance",
  "path": "AEP-Policy-System/reference/",
  "description": "NIST AI RMF compliance pack (GAP reference).",
  "requires": [
    "aep-base-node",
    "dynaep-core"
  ],
  "lrp_id": "nist-ai-rmf",
  "gap_ref": "AEP-Policy-System/reference/nist-ai-rmf.gap",
  "docks": {
    "primary": "regulation_module",
    "allowed": [
      "regulation_module"
    ]
  },
  "capabilities": [
    "compliance:nist-ai-rmf",
    "gap:evaluate"
  ],
  "actions": [
    {
      "id": "enable_nist-ai-rmf",
      "description": "Enable NIST AI RMF LRP",
      "setup_hook": "sync_lrp",
      "params": {
        "lrp_id": "nist-ai-rmf"
      }
    }
  ],
  "setup_hooks": [
    {
      "id": "sync_nist-ai-rmf",
      "setup_hook": "sync_lrp",
      "params": {
        "lrp_id": "nist-ai-rmf"
      }
    }
  ],
  "resource_requirements": {
    "min_memory_mb": 32,
    "min_disk_mb": 5,
    "requires_internet": false,
    "gpu_required": false
  },
  "cca": {
    "summary": "NIST AI RMF regulatory compliance via GAP policies.",
    "use_when": [
      "user requests NIST AI RMF",
      "regulated industry deployment"
    ],
    "avoid_when": [
      "no regulatory requirements"
    ],
    "pairs_with": [
      "gap-runtime-scanners",
      "wasm-policy-sandbox"
    ]
  },
  "implementation": {
    "gap_ref": "AEP-Policy-System/reference/nist-ai-rmf.gap"
  }
}
