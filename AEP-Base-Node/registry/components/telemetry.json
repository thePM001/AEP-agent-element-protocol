{
  "manifest_version": "1",
  "id": "telemetry",
  "version": "2.8.0",
  "kind": "library",
  "path": "AEP-Components/telemetry/",
  "description": "OpenTelemetry span and event exporter for AEP.",
  "requires": [
    "aep-typescript-sdk"
  ],
  "capabilities": [
    "telemetry:otel",
    "telemetry:export"
  ],
  "actions": [],
  "setup_hooks": [],
  "resource_requirements": {
    "min_memory_mb": 32,
    "min_disk_mb": 10,
    "requires_internet": false,
    "gpu_required": false
  },
  "cca": {
    "summary": "Export AEP spans to OpenTelemetry backends.",
    "use_when": [
      "observability stack integration"
    ],
    "avoid_when": [],
    "pairs_with": []
  },
  "implementation": {
    "module": "AEP-Components/telemetry/lib/otel-exporter.ts"
  }
}
