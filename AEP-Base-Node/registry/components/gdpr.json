{
  "manifest_version": "1",
  "id": "gdpr",
  "version": "2.8.0",
  "kind": "compliance",
  "path": "AEP-Policy-System/reference/",
  "description": "GDPR compliance pack (GAP reference).",
  "requires": [
    "aep-base-node",
    "dynaep-core"
  ],
  "lrp_id": "gdpr",
  "gap_ref": "AEP-Policy-System/reference/gdpr.gap",
  "docks": {
    "primary": "regulation_module",
    "allowed": [
      "regulation_module"
    ]
  },
  "capabilities": [
    "compliance:gdpr",
    "gap:evaluate"
  ],
  "actions": [
    {
      "id": "enable_gdpr",
      "description": "Enable GDPR LRP",
      "setup_hook": "sync_lrp",
      "params": {
        "lrp_id": "gdpr"
      }
    }
  ],
  "setup_hooks": [
    {
      "id": "sync_gdpr",
      "setup_hook": "sync_lrp",
      "params": {
        "lrp_id": "gdpr"
      }
    }
  ],
  "resource_requirements": {
    "min_memory_mb": 32,
    "min_disk_mb": 5,
    "requires_internet": false,
    "gpu_required": false
  },
  "cca": {
    "summary": "GDPR regulatory compliance via GAP policies.",
    "use_when": [
      "user requests GDPR",
      "regulated industry deployment"
    ],
    "avoid_when": [
      "no regulatory requirements"
    ],
    "pairs_with": [
      "gap-runtime-scanners",
      "wasm-policy-sandbox"
    ]
  },
  "implementation": {
    "gap_ref": "AEP-Policy-System/reference/gdpr.gap"
  }
}
