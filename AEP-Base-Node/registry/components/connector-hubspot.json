{
  "manifest_version": "1",
  "id": "connector-hubspot",
  "version": "2.8.0",
  "kind": "connector",
  "path": "AEP-Connectors/hubspot/",
  "description": "UCB-only HubSpot connector. All traffic via /ucb/v1/egress/hubspot/**.",
  "requires": [
    "aep-base-node",
    "lattice-channels",
    "ucb",
    "composer-lite"
  ],
  "capabilities": [
    "connector:hubspot",
    "ucb:egress-proxy",
    "integration:external-api"
  ],
  "actions": [
    {
      "id": "wire_hubspot",
      "description": "Wire HubSpot connector egress routes",
      "runtime": "plan",
      "method": "connector_config"
    },
    {
      "id": "probe_hubspot",
      "description": "Health probe for HubSpot",
      "runtime": "connector",
      "method": "probe"
    }
  ],
  "setup_hooks": [
    {
      "id": "hubspot_connector_default",
      "policy_section": "connectors",
      "default": {
        "hubspot": {
          "upstream": "https://api.hubapi.com"
        }
      }
    }
  ],
  "composer": {
    "palette": true,
    "node_type": "connector"
  },
  "composer_node": {
    "type": "connector",
    "label": "HubSpot",
    "short": "HU",
    "color": "#475569",
    "service": "hubspot",
    "ucb_only": true,
    "description": "HubSpot via UCB egress",
    "registry_id": "connector-hubspot"
  },
  "resource_requirements": {
    "min_memory_mb": 32,
    "min_disk_mb": 10,
    "requires_internet": true,
    "gpu_required": false
  },
  "cca": {
    "summary": "Connect HubSpot. Requires UCB. Routes: /ucb/v1/egress/hubspot/**.",
    "use_when": [
      "hubspot",
      "crm",
      "hub spot"
    ],
    "avoid_when": [
      "air-gapped with no external APIs",
      "UCB disabled"
    ],
    "pairs_with": [
      "ucb",
      "aep-base-node",
      "composer-lite"
    ]
  },
  "implementation": {
    "module": "AEP-Connectors/hubspot/lib/hubspot-connector.mjs",
    "ucb_egress_prefix": "/ucb/v1/egress/hubspot",
    "auth_token_env": "AEP_HUBSPOT_TOKEN"
  },
  "integration": {
    "ucb_only": true,
    "mcp_optional": null,
    "nango_compatible": true
  }
}
