{
  "manifest_version": "1",
  "id": "knowledge-base",
  "version": "2.8.0",
  "kind": "library",
  "path": "AEP-Components/knowledge-base/",
  "description": "Lattice-governed knowledge ingest and retrieval.",
  "requires": [
    "policy-engine",
    "aep-typescript-sdk"
  ],
  "capabilities": [
    "knowledge:ingest",
    "knowledge:retrieve",
    "knowledge:search"
  ],
  "actions": [],
  "setup_hooks": [],
  "resource_requirements": {
    "min_memory_mb": 256,
    "min_disk_mb": 100,
    "requires_internet": false,
    "gpu_required": false
  },
  "cca": {
    "summary": "RAG knowledge base under lattice governance.",
    "use_when": [
      "retrieval-augmented agents"
    ],
    "avoid_when": [],
    "pairs_with": []
  },
  "implementation": {
    "module": "AEP-Components/knowledge-base/lib/knowledge/manager.ts"
  }
}
