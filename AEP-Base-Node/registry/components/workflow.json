{
  "manifest_version": "1",
  "id": "workflow",
  "version": "2.8.0",
  "kind": "library",
  "path": "AEP-Components/workflow/",
  "description": "Multi-phase workflow executor and fine-tuning templates.",
  "requires": [
    "policy-engine",
    "aep-typescript-sdk"
  ],
  "capabilities": [
    "workflow:execute",
    "workflow:phases",
    "workflow:fine-tuning"
  ],
  "actions": [],
  "setup_hooks": [],
  "resource_requirements": {
    "min_memory_mb": 64,
    "min_disk_mb": 20,
    "requires_internet": false,
    "gpu_required": false
  },
  "cca": {
    "summary": "Phased workflows with per-phase verdicts.",
    "use_when": [
      "multi-step training pipelines"
    ],
    "avoid_when": [],
    "pairs_with": []
  },
  "implementation": {
    "module": "AEP-Components/workflow/lib/executor.ts"
  }
}
