{
  "manifest_version": "1",
  "id": "connector-jira",
  "version": "2.8.0",
  "kind": "connector",
  "path": "AEP-Connectors/jira/",
  "description": "UCB-only Jira connector. All traffic via /ucb/v1/egress/jira/**.",
  "requires": [
    "aep-base-node",
    "lattice-channels",
    "ucb",
    "composer-lite"
  ],
  "capabilities": [
    "connector:jira",
    "ucb:egress-proxy",
    "integration:external-api"
  ],
  "actions": [
    {
      "id": "wire_jira",
      "description": "Wire Jira connector egress routes",
      "runtime": "plan",
      "method": "connector_config"
    },
    {
      "id": "probe_jira",
      "description": "Health probe for Jira",
      "runtime": "connector",
      "method": "probe"
    }
  ],
  "setup_hooks": [
    {
      "id": "jira_connector_default",
      "policy_section": "connectors",
      "default": {
        "jira": {
          "upstream": "https://api.atlassian.com"
        }
      }
    }
  ],
  "composer": {
    "palette": true,
    "node_type": "connector"
  },
  "composer_node": {
    "type": "connector",
    "label": "Jira",
    "short": "JI",
    "color": "#475569",
    "service": "jira",
    "ucb_only": true,
    "description": "Jira via UCB egress",
    "registry_id": "connector-jira"
  },
  "resource_requirements": {
    "min_memory_mb": 32,
    "min_disk_mb": 10,
    "requires_internet": true,
    "gpu_required": false
  },
  "cca": {
    "summary": "Connect Jira. Requires UCB. Routes: /ucb/v1/egress/jira/**.",
    "use_when": [
      "jira",
      "atlassian",
      "jira ticket",
      "jira issue"
    ],
    "avoid_when": [
      "air-gapped with no external APIs",
      "UCB disabled"
    ],
    "pairs_with": [
      "ucb",
      "aep-base-node",
      "composer-lite"
    ]
  },
  "implementation": {
    "module": "AEP-Connectors/jira/lib/jira-connector.mjs",
    "ucb_egress_prefix": "/ucb/v1/egress/jira",
    "auth_token_env": "AEP_JIRA_API_TOKEN"
  },
  "integration": {
    "ucb_only": true,
    "mcp_optional": null,
    "nango_compatible": true
  }
}
