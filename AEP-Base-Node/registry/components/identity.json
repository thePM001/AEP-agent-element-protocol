{
  "manifest_version": "1",
  "id": "identity",
  "version": "2.8.0",
  "kind": "library",
  "path": "AEP-Components/identity/",
  "description": "Agent identity manager and compact identity types.",
  "requires": [
    "aep-typescript-sdk"
  ],
  "capabilities": [
    "identity:create",
    "identity:compact",
    "identity:attest"
  ],
  "actions": [],
  "setup_hooks": [],
  "resource_requirements": {
    "min_memory_mb": 32,
    "min_disk_mb": 10,
    "requires_internet": false,
    "gpu_required": false
  },
  "cca": {
    "summary": "Cryptographic agent identity for proof bundles.",
    "use_when": [
      "attested agents",
      "cross-agent handshake"
    ],
    "avoid_when": [],
    "pairs_with": []
  },
  "implementation": {
    "module": "AEP-Components/identity/lib/manager.ts"
  }
}
