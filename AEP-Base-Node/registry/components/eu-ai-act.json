{
  "manifest_version": "1",
  "id": "eu-ai-act",
  "version": "3.3.0",
  "kind": "compliance",
  "path": "AEP-Components/eu-ai-act-checker/EU-AI-ACT-PACK.json",
  "description": "EU AI Act compliance checking pack. One definition file, one gate. Not a legal certification.",
  "maturity": "enforced_v1",
  "requires": [
    "aep-base-node",
    "dynaep-core"
  ],
  "lrp_id": "eu-ai-act",
  "gap_ref": "AEP-Policy-System/reference/eu-ai-act.gap",
  "definition": "AEP-Components/eu-ai-act-checker/EU-AI-ACT-PACK.json",
  "gate": "AEP-Components/eu-ai-act-checker/gates/gate-eu-ai-act.sh",
  "implementation": {
    "gap_ref": "AEP-Policy-System/reference/eu-ai-act.gap",
    "checker": "AEP-Components/eu-ai-act-checker",
    "definition": "AEP-Components/eu-ai-act-checker/EU-AI-ACT-PACK.json",
    "gate": "AEP-Components/eu-ai-act-checker/gates/gate-eu-ai-act.sh"
  },
  "docks": {
    "primary": "regulation_module",
    "allowed": [
      "regulation_module"
    ]
  },
  "capabilities": [
    "compliance:eu-ai-act",
    "compliance:eu-ai-act:check",
    "gap:evaluate"
  ],
  "actions": [
    {
      "id": "enable_eu-ai-act",
      "description": "Enable EU AI Act checking pack",
      "setup_hook": "sync_lrp",
      "params": {
        "lrp_id": "eu-ai-act",
        "require_config": [
          "role",
          "risk_class"
        ]
      }
    },
    {
      "id": "evaluate_eu-ai-act",
      "description": "Evaluate action via eu-ai-act-checker",
      "method": "evaluate_lrp",
      "params": {
        "lrp_id": "eu-ai-act"
      }
    }
  ],
  "setup_hooks": [
    {
      "id": "sync_eu-ai-act",
      "setup_hook": "sync_lrp",
      "params": {
        "lrp_id": "eu-ai-act",
        "definition": "AEP-Components/eu-ai-act-checker/EU-AI-ACT-PACK.json",
        "gate": "AEP-Components/eu-ai-act-checker/gates/gate-eu-ai-act.sh",
        "validate_pack": true
      }
    }
  ],
  "resource_requirements": {
    "min_memory_mb": 64,
    "min_disk_mb": 20,
    "requires_internet": false,
    "gpu_required": false
  },
  "cca": {
    "summary": "EU AI Act fail-closed compliance checking. One pack file, one gate.",
    "use_when": [
      "user requests EU AI Act checking",
      "regulated industry deployment with technical control enforcement"
    ],
    "avoid_when": [
      "no regulatory requirements"
    ],
    "pairs_with": [
      "gap-runtime-scanners",
      "wasm-policy-sandbox"
    ],
    "required_plan_fields": [
      "eu_ai_act.role",
      "eu_ai_act.risk_class"
    ]
  }
}
