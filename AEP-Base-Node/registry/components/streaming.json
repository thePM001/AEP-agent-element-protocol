{
  "manifest_version": "1",
  "id": "streaming",
  "version": "2.8.0",
  "kind": "library",
  "path": "AEP-Components/streaming/",
  "description": "Stream validator and middleware for governed output.",
  "requires": [
    "scanners",
    "policy-engine",
    "aep-typescript-sdk"
  ],
  "capabilities": [
    "stream:validate",
    "stream:middleware",
    "stream:abort"
  ],
  "actions": [],
  "setup_hooks": [],
  "resource_requirements": {
    "min_memory_mb": 64,
    "min_disk_mb": 20,
    "requires_internet": false,
    "gpu_required": false
  },
  "cca": {
    "summary": "Real-time stream validation with scanner pipeline.",
    "use_when": [
      "streaming LLM output governance"
    ],
    "avoid_when": [],
    "pairs_with": []
  },
  "implementation": {
    "module": "AEP-Components/streaming/lib/validator.ts"
  }
}
