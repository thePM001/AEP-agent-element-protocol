{
  "manifest_version": "1",
  "id": "verification",
  "version": "2.8.0",
  "kind": "library",
  "path": "AEP-Components/verification/",
  "description": "Handshake proofs and counterparty verification.",
  "requires": [
    "proof-bundle",
    "aep-typescript-sdk"
  ],
  "capabilities": [
    "verify:handshake",
    "verify:counterparty"
  ],
  "actions": [],
  "setup_hooks": [],
  "resource_requirements": {
    "min_memory_mb": 32,
    "min_disk_mb": 10,
    "requires_internet": false,
    "gpu_required": false
  },
  "cca": {
    "summary": "Cross-agent verification via proof handshakes.",
    "use_when": [
      "multi-party agent trust"
    ],
    "avoid_when": [],
    "pairs_with": []
  },
  "implementation": {
    "module": "AEP-Components/verification/lib/handshake.ts"
  }
}
