{
  "name": "aep-agent-harness",
  "version": "2.2.0",
  "description": "AEP 2.2 Governance Layer for AI Code Agents",
  "main": "harness/aep-validate.js",
  "bin": {
    "aep-validate": "harness/aep-validate.js"
  },
  "scripts": {
    "validate": "node harness/aep-validate.js",
    "validate:src": "node harness/aep-validate.js --src=./src",
    "safety": "node harness/aep-safety-guard.js",
    "safety:watch": "node harness/aep-safety-guard.js --watch",
    "safety:pre-commit": "node harness/aep-safety-guard.js --pre-commit",
    "check": "node harness/aep-safety-guard.js && node harness/aep-validate.js"
  },
  "keywords": ["aep", "agent-element-protocol", "governance", "claude-code", "ai-agent", "validation"],
  "author": "New Lisbon Agency LLC",
  "license": "SEE LICENSE IN LICENSE",
  "optionalDependencies": {
    "js-yaml": "^4.1.0"
  }
}
