# Control Hub Environment Configuration
# Source this before running agent-bootstrap.sh or agent-harness.sh
#
# Usage: source config/control-hub.env

# --- REQUIRED ---
# Gitea access token (replace with your actual token)
export CONTROL_HUB_TOKEN=""

# --- Gitea Connection ---
export CONTROL_HUB_URL="http://100.118.184.18:3003"
export CONTROL_REPO_OWNER="thePM001"
export CONTROL_REPO_NAME="NLA-PLATFORM"

# --- GAP Runtime ---
export GAP_SERVER_URL="http://127.0.0.1:3200"

# --- Governance ---
# fail_closed = true: BLOCK if GAP unreachable
# fail_closed = false: ALLOW if GAP unreachable (dev only)
export GAP_FAIL_CLOSED="true"

# --- Boot Settings ---
export MAX_RETRIES="5"
export BACKOFF_SECONDS="2"

# --- Validation ---
export MARKER="control-hub"
export EXTENSIONS="py,js,ts,tsx,jsx,ex,rs,sh"
export SKIP_SHELLCHECK="false"

# --- Logging ---
export LOG_DIR="/var/log/agent-control"
export VERBOSE="false"

# --- Supervisor Center (future) ---
# export SUPERVISION_CENTER_URL="https://tasty.newlisbon.agency/staging/aep-supervision-center-26"
