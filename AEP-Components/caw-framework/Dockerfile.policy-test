# Automated policy test + interactive shell for aep-caw agent-default policy.
# Runs claude -p prompts through aep-caw wrap to validate policy enforcement.
#
# Build:
#   go build -o aep-caw ./cmd/aep-caw
#   go build -o aep-caw-unixwrap ./cmd/aep-caw-unixwrap
#   go build -o aep-caw-stub ./cmd/aep-caw-stub
#   docker build -f Dockerfile.policy-test -t aep-caw-policy-test .
#
# Run automated tests (default - requires claude binary + API key):
#   docker run --rm \
#     --security-opt seccomp=unconfined \
#     --cap-add SYS_PTRACE --cap-add SYS_ADMIN \
#     --device /dev/fuse \
#     --env-file .env \
#     -v "$(which claude):/usr/local/bin/claude:ro" \
#     aep-caw-policy-test
#
# Run automated tests with verbose output (show Claude responses):
#   docker run --rm \
#     --security-opt seccomp=unconfined \
#     --cap-add SYS_PTRACE --cap-add SYS_ADMIN \
#     --device /dev/fuse \
#     --env-file .env \
#     -v "$(which claude):/usr/local/bin/claude:ro" \
#     aep-caw-policy-test -v
#
# Run interactive mode:
#   docker run -it --rm \
#     --security-opt seccomp=unconfined \
#     --cap-add SYS_PTRACE --cap-add SYS_ADMIN \
#     --device /dev/fuse \
#     --env-file .env \
#     -v "$(which claude):/usr/local/bin/claude:ro" \
#     aep-caw-policy-test interactive

FROM debian:bookworm-slim

RUN apt-get update && \
    apt-get install -y --no-install-recommends \
      ca-certificates curl bash jq git nodejs npm \
      sudo netcat-openbsd procps python3 \
      fuse3 && \
    rm -rf /var/lib/apt/lists/*

# Copy locally-built binaries
COPY aep-caw /usr/bin/aep-caw
COPY aep-caw-unixwrap /usr/bin/aep-caw-unixwrap
COPY aep-caw-stub /usr/bin/aep-caw-stub
RUN chmod +x /usr/bin/aep-caw /usr/bin/aep-caw-unixwrap /usr/bin/aep-caw-stub

# Copy policies
COPY configs/policies/ /etc/aep-caw/policies/

# Create workspace and Claude config dir
RUN mkdir -p /work/app /root/.claude && \
    echo '{"permissions":{"allow":["Bash(*)","Read(*)","Write(*)","Edit(*)"]}}' \
      > /root/.claude/settings.json

# Copy policy test script
COPY test_policy.py /work/app/test_policy.py
RUN chmod +x /work/app/test_policy.py

# ---------------------------------------------------------------------------
# Embedded test script - runs claude -p through aep-caw wrap
# ---------------------------------------------------------------------------
COPY <<'TEST_SCRIPT' /test.sh
#!/bin/bash
set -euo pipefail

audit_log="$1"
server_log="$2"
verbose="${3:-false}"

passed=0
failed=0
tests_run=0

pass() {
  passed=$((passed + 1))
  tests_run=$((tests_run + 1))
  echo "  PASS: $1"
}

fail() {
  failed=$((failed + 1))
  tests_run=$((tests_run + 1))
  echo "  FAIL: $1 - $2" >&2
}

# -------------------------------------------------------------------
# Helper: run claude -p through aep-caw wrap
# Usage: claude_wrap "prompt" [timeout_secs]
# Sets: _cw_output (stdout+stderr), _cw_rc (exit code)
# -------------------------------------------------------------------
claude_wrap() {
  local prompt="$1"
  local max_secs="${2:-120}"
  _cw_output=""
  _cw_rc=0
  echo "    > claude -p \"${prompt:0:80}...\""
  set +e
  _cw_output="$(timeout "$max_secs" \
    aep-caw wrap --policy agent-default --root /work/app -- \
    claude -p "$prompt" --output-format text 2>/dev/null)"
  _cw_rc=$?
  set -e
  # Show Claude's response in verbose mode
  if [ "$verbose" = "true" ] && [ -n "$_cw_output" ]; then
    echo "    --- response ---"
    echo "$_cw_output" | sed 's/^/    /'
    echo "    --- end response ---"
  fi
}

# -------------------------------------------------------------------
# Helper: count audit log entries for a specific rule
audit_count() {
  local c
  c=$(grep -c "$1" "$audit_log" 2>/dev/null) || true
  echo "${c:-0}"
}

# Helper: run command via aep-caw exec --output json (fast pre-flight)
# -------------------------------------------------------------------
exec_json() {
  local session="$1"; shift
  set +e
  _ej_json="$(aep-caw exec --output json --events all "$session" -- "$@" 2>&1)"
  _ej_rc=$?
  set -e
}

# ===================================================================
# 1. Pre-flight: fast policy rule validation (no API calls)
# ===================================================================
echo ""
echo "=== 1. Pre-flight: policy rule validation ==="

sid_json="$(aep-caw session create --workspace /work/app --policy agent-default --json)"
sid="$(echo "$sid_json" | jq -r '.id')"
if [ -z "$sid" ] || [ "$sid" = "null" ]; then
  echo "ERROR: Failed to create session: $sid_json" >&2
  exit 1
fi

# Verify allow, deny, redirect rules work at the engine level
exec_json "$sid" echo preflight_ok
if [ "$_ej_rc" -eq 0 ]; then
  pass "pre-flight: echo allowed"
else
  fail "pre-flight: echo allowed" "exit code $_ej_rc"
fi

exec_json "$sid" sudo whoami
ej_rule="$(echo "$_ej_json" | jq -r '.result.error.policy_rule // empty')"
if [ "$ej_rule" = "deny-privilege-escalation" ]; then
  pass "pre-flight: sudo denied (deny-privilege-escalation)"
else
  fail "pre-flight: sudo denied" "got rule: $ej_rule"
fi

exec_json "$sid" git push --force origin main
ej_rule="$(echo "$_ej_json" | jq -r '.result.error.policy_rule // .guidance.policy_rule // .guidance.rule // empty')"
if [ "$ej_rule" = "redirect-git-force-push" ]; then
  pass "pre-flight: git push --force redirected"
else
  fail "pre-flight: git push --force redirected" "got rule: $ej_rule"
fi

echo "  Pre-flight OK - policy engine working, proceeding to Claude tests"

# ===================================================================
# 2. Claude: policy enforcement via test script
# ===================================================================
echo ""
echo "=== 2. Claude: policy enforcement via test script ==="

# Snapshot audit log counts before the Claude test
_before_priv="$(audit_count deny-privilege-escalation)"
_before_admin="$(audit_count deny-system-admin)"
_before_net="$(audit_count deny-raw-network)"
_before_pkg="$(audit_count deny-system-pkg-install)"
_before_force="$(audit_count redirect-git-force-push)"
_before_reset="$(audit_count redirect-git-hard-reset)"
_before_clean="$(audit_count redirect-git-clean)"
_before_rm="$(audit_count redirect-destructive-rm)"

claude_wrap "Run python3 /work/app/test_policy.py and show its complete output. Do not modify the script or skip any part. Just run it and show what it prints." 180

# Parse JSON summary from the Python script output
_py_json="$(echo "$_cw_output" | grep -oE '\{"passed": [0-9]+, "failed": [0-9]+, "total": [0-9]+\}' | tail -1 || true)"
if [ -n "$_py_json" ]; then
  _py_passed="$(echo "$_py_json" | jq -r '.passed')"
  _py_failed="$(echo "$_py_json" | jq -r '.failed')"
  _py_total="$(echo "$_py_json" | jq -r '.total')"
  if [ "$_py_failed" -eq 0 ]; then
    pass "claude ran test script ($_py_total sub-tests: $_py_passed passed, $_py_failed failed)"
  else
    fail "claude ran test script ($_py_total sub-tests: $_py_passed passed, $_py_failed failed)" "$_py_failed sub-tests failed"
  fi
else
  # Fallback: check if any PASS/FAIL lines appear
  _pass_count="$(echo "$_cw_output" | grep -c "PASS:" 2>/dev/null)" || true
  _pass_count="${_pass_count:-0}"
  _fail_count="$(echo "$_cw_output" | grep -c "FAIL:" 2>/dev/null)" || true
  _fail_count="${_fail_count:-0}"
  if [ "$_pass_count" -gt 0 ] && [ "$_fail_count" -eq 0 ]; then
    pass "claude ran test script ($_pass_count sub-tests passed, no JSON summary)"
  elif [ "$_pass_count" -gt 0 ]; then
    fail "claude ran test script" "$_fail_count sub-tests failed (no JSON summary)"
  else
    fail "claude ran test script" "could not parse results; output: ${_cw_output:0:500}"
  fi
fi

# Wait briefly for audit log writes to flush
sleep 0.5

# -------------------------------------------------------------------
# Audit log verification - proof that aep-caw blocked each operation
# -------------------------------------------------------------------
audit_check() {
  local rule="$1"
  local label="$2"
  local before="$3"
  local expected_min="${4:-1}"
  local after
  after="$(audit_count "$rule")"
  local new_events=$((after - before))
  if [ "$new_events" -ge "$expected_min" ]; then
    pass "audit log: $rule ($new_events new event(s))"
  else
    fail "audit log: $rule" "expected >=$expected_min new events, got $new_events"
  fi
}

audit_check "deny-privilege-escalation" "sudo+su" "$_before_priv" 2
audit_check "deny-system-admin" "shutdown" "$_before_admin" 1
audit_check "deny-raw-network" "nc" "$_before_net" 1
audit_check "deny-system-pkg-install" "apt-get" "$_before_pkg" 1
audit_check "redirect-git-force-push" "force push" "$_before_force" 2
audit_check "redirect-git-hard-reset" "hard reset" "$_before_reset" 1
audit_check "redirect-git-clean" "git clean" "$_before_clean" 1
audit_check "redirect-destructive-rm" "rm -rf" "$_before_rm" 1

# ===================================================================
# 3. Audit log integrity
# ===================================================================
echo ""
echo "=== 3. Audit log integrity ==="

if [ -f "$audit_log" ] && [ -s "$audit_log" ]; then
  pass "audit log exists and is non-empty"
else
  fail "audit log exists and is non-empty" "file: $audit_log exists=$([ -f "$audit_log" ] && echo yes || echo no)"
fi

if [ -f "$audit_log" ]; then
  if grep -qE '"deny|"redirect' "$audit_log" 2>/dev/null; then
    event_count="$(grep -cE '"deny|"redirect' "$audit_log")"
    pass "audit log contains policy enforcement events (count=$event_count)"
  else
    fail "audit log contains policy enforcement events" "no deny/redirect entries found"
  fi
fi

# ===================================================================
# Summary
# ===================================================================
echo ""
echo "=== Results: ${passed} passed, ${failed} failed, ${tests_run} total ==="

if [ "$failed" -gt 0 ]; then
  echo ""
  echo "--- server log (last 80 lines) ---" >&2
  tail -80 "$server_log" >&2 || true
  echo "--- end server log ---" >&2
  exit 1
fi

exit 0
TEST_SCRIPT
RUN chmod +x /test.sh

# ---------------------------------------------------------------------------
# Entrypoint: start server, then dispatch to test or interactive mode
# ---------------------------------------------------------------------------
COPY <<'ENTRYPOINT_SCRIPT' /entrypoint.sh
#!/bin/bash
set -euo pipefail

tmp="$(mktemp -d)"

# Docker --env-file doesn't strip quotes; remove them from API keys.
if [ -n "${ANTHROPIC_API_KEY:-}" ]; then
  ANTHROPIC_API_KEY="${ANTHROPIC_API_KEY%\"}"
  ANTHROPIC_API_KEY="${ANTHROPIC_API_KEY#\"}"
  export ANTHROPIC_API_KEY
fi
cleanup() {
  set +e
  [ -n "${SERVER_PID:-}" ] && kill "$SERVER_PID" 2>/dev/null
  # Unmount FUSE workspace mounts before removing tmp
  for mnt in "$tmp"/sessions/*/workspace-mnt; do
    [ -d "$mnt" ] && umount "$mnt" 2>/dev/null
  done
  rm -rf "$tmp" 2>/dev/null
}
trap cleanup EXIT

port=18923
base_url="http://127.0.0.1:${port}"
export AEP_CAW_SERVER="$base_url"

cat >"$tmp/config.yml" <<YAML
server:
  http:
    addr: "127.0.0.1:${port}"
  grpc:
    enabled: false
  unix_socket:
    enabled: false
auth:
  type: "none"
logging:
  level: "debug"
  format: "text"
metrics:
  enabled: false
health:
  path: "/health"
  readiness_path: "/ready"
policies:
  dir: "/etc/aep-caw/policies"
  default: "agent-default"
sessions:
  base_dir: "${tmp}/sessions"
  max_sessions: 10
audit:
  enabled: true
  output: "${tmp}/audit.jsonl"
  storage:
    sqlite_path: "${tmp}/events.db"
sandbox:
  enabled: true
  allow_degraded: true
  fuse:
    enabled: true
    audit:
      mode: "monitor"
  network:
    enabled: false
  cgroups:
    enabled: false
  unix_sockets:
    enabled: false
  seccomp:
    enabled: true
    unix_socket:
      enabled: false
    execve:
      enabled: true
proxy:
  mode: "embedded"
  port: 0
  providers:
    anthropic: "https://api.anthropic.com"
    openai: "https://api.openai.com"
dlp:
  mode: "redact"
  patterns:
    email: true
    phone: true
    credit_card: true
    ssn: true
    api_keys: true
llm_storage:
  store_bodies: true
  retention:
    max_age_days: 7
    max_size_mb: 100
YAML

echo "Starting aep-caw server..."
aep-caw server --config "$tmp/config.yml" >"$tmp/server.log" 2>&1 &
SERVER_PID="$!"

server_ready=0
for _ in $(seq 1 100); do
  if curl -fsS "${base_url}/health" >/dev/null 2>&1; then
    server_ready=1
    break
  fi
  sleep 0.1
done

if [ "$server_ready" != "1" ]; then
  echo "ERROR: Server did not become ready" >&2
  echo "--- server log ---" >&2
  head -100 "$tmp/server.log" >&2 || true
  echo "--- end server log ---" >&2
  exit 1
fi
echo "Server ready (PID: $SERVER_PID)"

# ---------------------------------------------------------------------------
# Dispatch: interactive mode vs automated test mode
# ---------------------------------------------------------------------------
mode="${1:-test}"
verbose=false
for arg in "$@"; do
  case "$arg" in
    interactive) mode="interactive" ;;
    -v|--verbose) verbose=true ;;
  esac
done

if [ "$mode" = "interactive" ]; then

  echo ""
  if command -v claude >/dev/null 2>&1; then
    echo "Claude Code: $(claude --version 2>/dev/null || echo 'version unknown')"
  else
    echo "Claude Code: not found (mount via -v \$(which claude):/usr/local/bin/claude:ro)"
  fi

  if [ -n "${ANTHROPIC_API_KEY:-}" ]; then
    echo "Auth: ANTHROPIC_API_KEY set"
  else
    echo "Auth: ANTHROPIC_API_KEY not set (pass --env-file .env)"
  fi
  echo ""

  if [ -e /dev/fuse ]; then
    echo "FUSE: /dev/fuse available"
  else
    echo "FUSE: /dev/fuse NOT available (mount with --device /dev/fuse)"
  fi
  echo ""

  echo "================================================================"
  echo "  aep-caw wrap - agent-default policy (seccomp + FUSE)"
  echo "  Workspace: /work/app"
  echo ""
  echo "  Run Claude Code:  claude -p 'your prompt'"
  echo "  Interactive:       claude"
  echo "  View LLM logs:    aep-caw llm-logs \$AEP_CAW_SESSION_ID"
  echo "  View audit log:   cat ${tmp}/audit.jsonl | jq ."
  echo "================================================================"
  echo ""

  exec aep-caw wrap --policy agent-default --root /work/app -- /bin/bash -c '
    if [ -n "$AEP_CAW_WORKSPACE_MOUNT" ] && cd "$AEP_CAW_WORKSPACE_MOUNT" 2>/dev/null; then
      echo "aep-caw: FUSE active - working directory: $(pwd)" >&2
    fi
    export PS1="aep-caw:/work/app\$ "
    exec /bin/bash --norc -i
  '
else
  # Automated test mode - requires claude binary + API key
  echo ""
  echo "=== aep-caw policy-test: agent-default automated validation ==="
  echo ""

  # Check prerequisites
  prereqs_ok=true

  if ! command -v claude >/dev/null 2>&1; then
    echo "ERROR: claude binary not found." >&2
    echo "  Mount it: -v \"\$(which claude):/usr/local/bin/claude:ro\"" >&2
    prereqs_ok=false
  else
    echo "Claude Code: $(claude --version 2>/dev/null || echo 'found')"
  fi

  if [ -z "${ANTHROPIC_API_KEY:-}" ]; then
    echo "ERROR: ANTHROPIC_API_KEY not set." >&2
    echo "  Pass it: --env-file .env" >&2
    prereqs_ok=false
  else
    echo "Auth: ANTHROPIC_API_KEY set"
  fi

  if [ "$prereqs_ok" != "true" ]; then
    echo "" >&2
    echo "Usage:" >&2
    echo "  docker run --rm \\" >&2
    echo "    --security-opt seccomp=unconfined \\" >&2
    echo "    --cap-add SYS_PTRACE --cap-add SYS_ADMIN \\" >&2
    echo "    --device /dev/fuse \\" >&2
    echo "    --env-file .env \\" >&2
    echo "    -v \"\$(which claude):/usr/local/bin/claude:ro\" \\" >&2
    echo "    aep-caw-policy-test" >&2
    exit 1
  fi

  echo "Audit log: ${tmp}/audit.jsonl"
  echo ""

  /test.sh "${tmp}/audit.jsonl" "$tmp/server.log" "$verbose"
fi
ENTRYPOINT_SCRIPT
RUN chmod +x /entrypoint.sh

WORKDIR /work/app
ENTRYPOINT ["/bin/bash", "/entrypoint.sh"]
