FROM golang:1.25
RUN apt-get update && apt-get install -y netcat-openbsd && rm -rf /var/lib/apt/lists/*
WORKDIR /src
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN go test -c -tags integration -o /ptrace-test ./internal/ptrace/
ENTRYPOINT ["/ptrace-test"]
CMD ["-test.v", "-test.timeout=120s"]
