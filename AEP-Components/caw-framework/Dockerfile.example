# Example: Debian-based image that installs aep-caw from a GitHub Release .deb
# and opt-in activates the /bin/sh + /bin/bash shim.
#
# Build:
#   docker build -f Dockerfile.example \
#     --build-arg AEP_CAW_REPO=canyonroad/aep-caw \
#     --build-arg AEP_CAW_TAG=v0.10.1 \
#     --build-arg DEB_ARCH=amd64 \
#     -t aep-caw-example:latest .
#
# Run (connect to an external aep-caw server):
#   docker run --rm -e AEP_CAW_SERVER=http://host.docker.internal:8080 aep-caw-example:latest
#
# Notes:
# - The release tag is "v..." but the artifact filenames use the version without the "v" prefix.
# - DEB_ARCH must match the artifact name (typically: amd64 or arm64).
# - Set AEP_CAW_SERVER to point at the aep-caw server (e.g. http://host.docker.internal:8080).
# - To select a non-default policy at runtime, set env var AEP_CAW_POLICY_NAME to an allowed policy name.
# - To block env iteration for matched commands, set AEP_CAW_ENV_BLOCK_ITERATION=1 (requires env shim LD_PRELOAD if used).

FROM debian:bookworm-slim

ARG AEP_CAW_REPO=canyonroad/aep-caw
ARG AEP_CAW_TAG=v0.10.1
ARG DEB_ARCH=amd64

RUN set -eux; \
  apt-get update; \
  apt-get install -y --no-install-recommends ca-certificates curl bash; \
  rm -rf /var/lib/apt/lists/*

RUN set -eux; \
  version="${AEP_CAW_TAG#v}"; \
  deb="aep-caw_${version}_linux_${DEB_ARCH}.deb"; \
  url="https://github.com/${AEP_CAW_REPO}/releases/download/${AEP_CAW_TAG}/${deb}"; \
  echo "Downloading: ${url}"; \
  curl -fsSL -L "${url}" -o /tmp/aep-caw.deb; \
  dpkg -i /tmp/aep-caw.deb; \
  rm -f /tmp/aep-caw.deb; \
  aep-caw --version; \
  aep-caw shim install-shell \
    --root / \
    --shim /usr/bin/aep-caw-shell-shim \
    --bash \
    --i-understand-this-modifies-the-host

CMD ["/bin/sh", "-lc", "echo hello from aep-caw shim; true"]
