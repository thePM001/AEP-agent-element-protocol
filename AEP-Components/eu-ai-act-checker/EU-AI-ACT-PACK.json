  "evidence_schemas": {
    "fria-record.v1": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "type": "object",
      "required": [
        "fria_id",
        "summary"
      ],
      "properties": {
        "fria_id": {
          "type": "string"
        },
        "summary": {
          "type": "string"
        },
        "date": {
          "type": "string"
        }
      },
      "additionalProperties": true
    },
    "human-oversight-mode.v1": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "type": "object",
      "required": [
        "mode"
      ],
      "properties": {
        "mode": {
          "type": "string",
          "enum": [
            "human_in_the_loop",
            "human_on_the_loop",
            "human_in_command"
          ]
        },
        "gate_required_for_high_impact": {
          "type": "boolean"
        }
      },
      "additionalProperties": true
    },
    "retention-config.v1": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "type": "object",
      "required": [
        "retention_days"
      ],
      "properties": {
        "retention_days": {
          "type": "integer",
          "minimum": 1
        },
        "export_on_request": {
          "type": "boolean"
        }
      },
      "additionalProperties": true
    },
    "risk-management-system.v1": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "type": "object",
      "required": [
        "version",
        "risk_tiers",
        "owner"
      ],
      "properties": {
        "version": {
          "type": "string",
          "minLength": 1
        },
        "risk_tiers": {
